{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "karta-web": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": {
          "style": "scss",
          "standalone": false
        },
        "@schematics/angular:directive": {
          "standalone": false
        },
        "@schematics/angular:pipe": {
          "standalone": false
        }
      },
      "root": "",
      "sourceRoot": "src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/karta-web",
            "index": "src/index.html",
            "browser": "src/main.ts",
            "polyfills": [
              "zone.js"
            ],
            "tsConfig": "tsconfig.app.json",
            "inlineStyleLanguage": "scss",
            "allowedCommonJsDependencies": [
              "cytoscape-fcose",
              "cytoscape-cose-bilkent",
              "@braintree/sanitize-url",
              "dayjs",
              "dayjs/plugin/isoWeek",
              "dayjs/plugin/customParseFormat",
              "dayjs/plugin/advancedFormat",
              "quill-delta",
              "debug",
              "vscode-jsonrpc"
            ],
            "assets": [
              "src/favicon.png",
              "src/assets",
              "src/robots.txt"
            ],
            "styles": [
              "node_modules/ngx-toastr/toastr.css",
              "bootstrap/scss/bootstrap.scss",
              "@angular/material/prebuilt-themes/azure-blue.css",
              "src/styles.scss"
            ],
            "stylePreprocessorOptions": {
              "includePaths": [
                "node_modules"
              ]
            },
            "scripts": [
              "bootstrap/dist/js/bootstrap.bundle.min.js"
            ]
          },
          "configurations": {
            "production": {
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "40MB",
                  "maximumError": "40MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10000kB",
                  "maximumError": "10000kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/config/environment.ts",
                  "with": "src/config/environment.prod.ts"
                }
              ]
            },
            "staging": {
              "optimization": true,
              "extractLicenses": true,
              "sourceMap": true,
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "40MB",
                  "maximumError": "40MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10000kB",
                  "maximumError": "10000kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "src/config/environment.ts",
                  "with": "src/config/environment.staging.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true,
              "outputHashing": "all",
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "40MB",
                  "maximumError": "40MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "10000kB",
                  "maximumError": "10000kB"
                }
              ],
              "fileReplacements": [
                {
                  "replace": "src/config/environment.ts",
                  "with": "src/config/environment.dev.ts"
                }
              ]
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "karta-web:build:production"
            },
            "staging": {
              "buildTarget": "karta-web:build:staging"
            },
            "development": {
              "buildTarget": "karta-web:build:development"
            }
          },
          "options": {
            "proxyConfig": "proxy.conf.json"
          },
          "defaultConfiguration": "development"
        },
        "extract-i18n": {
          "builder": "@angular-devkit/build-angular:extract-i18n"
        },
        "test": {
          "builder": "@angular-devkit/build-angular:karma",
          "options": {
            "polyfills": [
              "zone.js",
              "zone.js/testing"
            ],
            "tsConfig": "tsconfig.spec.json",
            "inlineStyleLanguage": "scss",
            "assets": [
              {
                "glob": "**/*",
                "input": "public"
              }
            ],
            "styles": [
              "node_modules/ngx-toastr/toastr.css",
              "bootstrap/scss/bootstrap.scss",
              "node_modules/quill/dist/quill.snow.css",
              "@angular/material/prebuilt-themes/azure-blue.css"
            ],
            "scripts": []
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}
